APP_DOMAIN=chat.example.com
ACCESS_MODE=traefik
TRAEFIK_NETWORK=traefik-public
TRAEFIK_ACME_EMAIL=admin@example.com
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_WS_URL=
POSTGRES_DB=codexchat
POSTGRES_USER=codexchat
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg://codexchat:change_me@codexchat_db:5432/codexchat
APP_ENV=production
LOG_LEVEL=INFO
LOG_PRETTY=false
REDIS_URL=redis://redis:6379
SESSION_SECRET=replace_with_long_random_secret
SESSION_COOKIE_NAME=codexchat_session
CSRF_COOKIE_NAME=codexchat_csrf
SESSION_TTL_HOURS=168
CODEX_AUTH=chatgpt
CODEX_HOST_NODE_PATH=/usr/bin/node
CODEX_HOST_NODE_MODULES_PATH=/usr/lib/node_modules
CODEX_HOST_AUTH_PATH=/root/.codex
CODEX_CONTAINER_NODE_PATH=/usr/local/bin/node
CODEX_CONTAINER_NODE_MODULES_PATH=/usr/local/lib/node_modules
CODEX_CONTAINER_AUTH_PATH=/root/.codex
WORKSPACE_PATH=./workspace
HEARTBEAT_POLL_INTERVAL_SECONDS=15
HEARTBEAT_CLAIM_BATCH_SIZE=5
HEARTBEAT_MIN_INTERVAL_MINUTES=5
HEARTBEAT_INTERVAL_PRESETS=[5,15,30,60]
HEARTBEAT_RUN_STALE_AFTER_SECONDS=900
HEARTBEAT_ALLOWED_BASE_PATH=
UPLOADS_PATH=./uploads
ENABLE_PUBLIC_REGISTRATION=false
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change_me
ADMIN_BOOTSTRAP_PASSWORD_HASH=
# Backward-compatible aliases:
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=
